{
  "name": "coalesce-transform-mcp",
  "version": "0.1.1",
  "description": "MCP server for the Coalesce Transform API; run tools support Snowflake Key Pair auth only",
  "main": "dist/index.js",
  "bin": {
    "coalesce-transform-mcp": "./dist/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "tsc --watch",
    "import:node-type-corpus": "node scripts/import-node-type-corpus.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "coalesce", "transform", "model-context-protocol"],
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/jessemarshall/coalesce-transform-mcp.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "yaml": "^2.8.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
